{
	"name": "wpstatic/wpstatic",
	"description": "Generate static HTML versions of your WordPress site",
	"type": "wordpress-plugin",
	"version": "1.0.0",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5",
		"wp-phpunit/wp-phpunit": "^6.0",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"WPStatic\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"WPStatic\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "/opt/lampp/bin/php vendor/phpunit/phpunit/phpunit",
		"test-coverage": "/opt/lampp/bin/php vendor/phpunit/phpunit/phpunit --coverage-html coverage"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
